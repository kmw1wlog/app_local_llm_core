{
  "name": "ai-workos-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/next/dist/bin/next lint",
    "android:init": "sh -c 'if [ ! -d android ]; then npx cap add android; fi'",
    "cap:prepare": "node scripts/create-capacitor-web.mjs",
    "cap:sync": "npm run cap:prepare && npm run android:init && npx cap sync android",
    "android:debug-apk": "cd android && ./gradlew assembleDebug",
    "android:release-apk": "cd android && ./gradlew assembleRelease",
    "android:release-aab": "cd android && ./gradlew bundleRelease",
    "smoke:pre-apk": "tsx scripts/smoke-pre-apk.ts"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
